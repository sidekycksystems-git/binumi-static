---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Binumi · Page not found"
  description="The page you are looking for has moved or no longer exists."
>
  <main>
    <section class="section notfound" id="notfound">
      <div class="container">

        <div class="notfound-hero">
          <h1>This page isn't <span class="hl">here</span>.</h1>
          <p class="lead">
            The page you are looking for has moved or no longer exists. Here is where to go next.
          </p>

          <div class="notfound-actions">
            <a class="btn btn-primary" href="/">Back to home</a>
            <a class="btn btn-outline" href="/solutions/">Solutions</a>
            <a class="btn btn-outline" href="/insights/">Insights</a>
          </div>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .notfound {
    padding-block: var(--section-y, 5rem);
  }

  .notfound .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .notfound-hero {
    text-align: center;
    max-width: 42rem;
  }

  .notfound-hero h1 {
    margin-bottom: 1rem;
  }

  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
