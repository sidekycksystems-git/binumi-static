---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoFrame from '../../components/VideoFrame.astro';
---
<BaseLayout
  title="Binumi · Why the video scaling model works"
  description="Named-client proof across fintech, insurance, events, tech, consultancy and industrial teams."
  current="solution"
>
  <main>
    <!-- ===================== PAGE BANNER ===================== -->
    <section class="page-banner">
      <div class="container hero-inner">
        <h1>See what becomes possible across your <span class="hl">whole organization</span>.</h1>
        <p class="lead">
          Every team has expertise that wins deals, retains people and lands change. We turn it
          into precise, on-brand video at scale, so the value trapped in your decks and documents
          starts earning, and the proof is in the work we have already done.
        </p>
        <div class="banner-actions">
          <a class="btn btn-primary" href="#cta">See what becomes possible
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
          </a>
          <a class="btn btn-outline" href="#industries-proof">See the proof</a>
        </div>
        <VideoFrame tag="Brand film master" label="Binumi proof overview video" />
      </div>
    </section>

    <!-- ===================== SMART-PLATFORM BENTO ===================== -->
    <section class="section">
      <div class="container stack">
        <div class="intro">
          <h2>A platform, with <span class="hl">a team behind it</span>.</h2>
          <p class="subtitle">The platform does the production. The team makes sure it performs.</p>
        </div>
        <div class="bento reveal">
          <div class="bento-card b-wide">
            <h3>Any input becomes video</h3>
            <p>Decks, reports, footage, transcripts, the knowledge your people carry. The platform turns what you already have into finished, on-brand video.</p>
            <div class="input-flow">
              <div class="input-stack">
                <span class="input-node">
                  <span class="material-symbols-outlined" aria-hidden="true">slideshow</span>
                  Decks
                </span>
                <span class="input-node">
                  <span class="material-symbols-outlined" aria-hidden="true">description</span>
                  Reports
                </span>
                <span class="input-node">
                  <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
                  Knowledge
                </span>
              </div>
              <span class="flow-arrow material-symbols-outlined" aria-hidden="true">arrow_forward</span>
              <VideoFrame class="input-video" label="Any input becomes finished, on-brand video" />
            </div>
          </div>
          <div class="bento-card b-cell">
            <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">verified_user</span></div>
            <h3>On-brand by default</h3>
            <p>Your brand rules are built in, so every video is compliant, whoever makes it.</p>
          </div>
          <div class="bento-card b-cell">
            <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">movie</span></div>
            <h3>15 million rights-cleared clips</h3>
            <p>Footage, music and motion, with the rights already sorted.</p>
          </div>
          <div class="bento-card b-cell">
            <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">groups</span></div>
            <h3>An expert service team</h3>
            <p>Set-up, direction and quality control from people who do this for a living.</p>
          </div>
          <div class="bento-card b-cell">
            <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">bar_chart</span></div>
            <h3>Scales with your organization</h3>
            <p>Every team, every purpose, every channel, without adding headcount.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== SERVICE FEATURE BLOCK ===================== -->
    <section class="section">
      <div class="container">
        <div class="feature-block reveal">
          <div class="fb-grid">
            <div class="fb-copy">
              <h2>Set up by people who <span class="hl">do this for a living</span>.</h2>
              <div class="fb-items">
                <div class="fb-item">
                  <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">settings</span></div>
                  <h3>Brand build</h3>
                  <p>We configure Binumi around your brand, your content and your goals, so you are ready from day one.</p>
                </div>
                <div class="fb-item">
                  <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span></div>
                  <h3>Creative direction</h3>
                  <p>Our team finds the story and shapes it, whatever the brief or the goal.</p>
                </div>
                <div class="fb-item">
                  <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">verified_user</span></div>
                  <h3>Quality control</h3>
                  <p>Every video is checked against your standard before it goes out.</p>
                </div>
                <div class="fb-item">
                  <div class="icon"><span class="material-symbols-outlined" aria-hidden="true">how_to_reg</span></div>
                  <h3>Ongoing partnership</h3>
                  <p>We stay alongside as your needs grow, so the capability sharpens and pays back more over time.</p>
                </div>
              </div>
            </div>
            <div class="fb-media">
              <VideoFrame label="Expert service team video" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== WHY IT WORKS (six-industry proof) ===================== -->
    <!-- Proof-carrying counterpart to the homepage's lighter teaser. PROOF leads:
         named client + figures are the most prominent element; the claim sits above
         as context. Fintech is deliberately quieter (a flagged content gap, no invented
         number). Each card links to /industries/[industry]. -->
    <section class="section" id="industries-proof">
      <div class="container stack">
        <div class="intro">
          <h2>Why it works in <span class="hl">your world</span>.</h2>
          <p class="subtitle">Same platform, same service team, same standard. The proof is the named work, in the sector you recognize.</p>
        </div>
        <div class="wiw-grid reveal">

          <article class="card wiw-card lighter">
            <span class="kicker">Fintech</span>
            <p class="wiw-claim">Move at the speed of fintech. Without losing trust.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">Proof in progress</span>
              <p class="wiw-figures">Trusted across <span class="stat">80+</span> enterprises including Fujitsu and Generali. ISO 27001 certified, GDPR-compliant.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/financial-services/">See what becomes possible</a>
          </article>

          <article class="card wiw-card">
            <span class="kicker">Insurance</span>
            <p class="wiw-claim">Make policy something people actually understand.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">Generali</span>
              <p class="wiw-figures"><span class="stat">500+</span> videos across <span class="stat">12</span> European markets, in <span class="stat">12</span> languages. <span class="stat">80%</span> faster production.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/financial-services/">See what becomes possible</a>
          </article>

          <article class="card wiw-card lighter">
            <span class="kicker">Events</span>
            <p class="wiw-claim">Turn one event into a year of content.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">Proof in progress</span>
              <p class="wiw-figures">Event content for <span class="stat">80+</span> enterprises including Fujitsu and Generali. ISO 27001 certified, GDPR-compliant.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/events/">See what becomes possible</a>
          </article>

          <article class="card wiw-card">
            <span class="kicker">Tech</span>
            <p class="wiw-claim">Make complex technology obvious.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">Fujitsu</span>
              <p class="wiw-figures"><span class="stat">100+</span> slide decks replaced with 90-second videos. <span class="stat">5x</span> post-meeting engagement. <span class="stat">&pound;1M+</span> in revenue influenced.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/technology/">See what becomes possible</a>
          </article>

          <article class="card wiw-card">
            <span class="kicker">Consultancy</span>
            <p class="wiw-claim">Take your expertise out of the deck.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">S2 Partnership</span>
              <p class="wiw-figures">Onboarding support calls down around <span class="stat">80%</span>. Social engagement <span class="stat">tripled</span>. <span class="stat">100+</span> videos in year one.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/professional-services/">See what becomes possible</a>
          </article>

          <article class="card wiw-card">
            <span class="kicker">Industrials</span>
            <p class="wiw-claim">The work is complex. The story shouldn&rsquo;t be.</p>
            <div class="wiw-rule"></div>
            <div class="wiw-proof">
              <span class="wiw-client">Heathrow, Brabazon and Fujitsu</span>
              <p class="wiw-figures">Complex proposals and smart-city projects distilled into video stakeholders understand.</p>            </div>
            <a class="btn btn-outline btn-sm wiw-cta" href="/industries/industrials/">See what becomes possible</a>
          </article>

        </div>
      </div>
    </section>

    <!-- ===================== FAQ ACCORDION ===================== -->
    <section class="section">
      <div class="container">
        <div class="faq-grid">
          <div class="faq-intro">
            <h2>Questions, answered.</h2>
            <p class="lead">The practical detail behind the platform and the service.</p>
              <VideoFrame label="Question and answer video" />
          </div>
          <div class="faq-list">
            <details class="faq-item" open>
              <summary><span>Is Binumi a tool or a service?</span><span class="chev material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
              <div class="faq-body">Both. You get the AI platform and an expert service team. The platform does the production; the team sets it up, directs it and checks the quality.</div>
            </details>
            <details class="faq-item">
              <summary><span>Who in my organization can make video?</span><span class="chev material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
              <div class="faq-body">Anyone. Brand rules are built in, so output stays on-brand whoever creates it, with no production queue to wait on.</div>
            </details>
            <details class="faq-item">
              <summary><span>Where does the footage come from?</span><span class="chev material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
              <div class="faq-body">From 15 million rights-cleared clips, alongside your own assets. The rights are already sorted, so nothing holds up publishing.</div>
            </details>
            <details class="faq-item">
              <summary><span>Can it work across markets and languages?</span><span class="chev material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
              <div class="faq-body">Yes. One video can be produced across markets and languages on the same brand standard, as Generali does across 12 European markets.</div>
            </details>
            <details class="faq-item">
              <summary><span>Is it secure and compliant?</span><span class="chev material-symbols-outlined" aria-hidden="true">expand_more</span></summary>
              <div class="faq-body">Binumi is ISO 27001 certified and GDPR-compliant.</div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CLOSE ===================== -->
    <section class="section" id="cta">
      <div class="container">
        <div class="cta-card">
          <video class="cta-bg" src="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__e9fd886d8dacac140457e375d606c8a0_h169.mp4"
            autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
          <div class="inner">
            <h2>See why it works in <span class="hl">your world</span>.</h2>
            <p class="lead">Bring your brief. We will show you what becomes possible, and what it could be worth, with the named work to back it.</p>
            <a class="btn btn-primary" href="/solutions/">Start your proof of value
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  /* ===========================================================
     PAGE BANNER  (Automark features banner, repainted; centered)
     =========================================================== */
  .page-banner { padding-top: var(--nav-to-hero); padding-bottom: var(--section-y); }
  .hero-inner { display: flex; flex-direction: column; align-items: flex-start; text-align: left;
    gap: clamp(1.5rem, 1rem + 1.6vw, 2.6rem); }
  .hero-inner h1 { max-width: 24ch; text-wrap: balance; }
  .hero-inner .lead { max-width: 52ch; }
  .hero-inner .video-master { margin-top: clamp(1rem, .5rem + 1.5vw, 2rem); max-width: 980px; }
  .banner-actions { display: flex; gap: .85rem; flex-wrap: wrap; justify-content: flex-start; }

  /* ===========================================================
     SMART-PLATFORM BENTO  (Automark ShowcaseCard grid)
     =========================================================== */
  .bento { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem; }
  .bento-card { display: flex; flex-direction: column; gap: 1rem; padding: 1.9rem; border-radius: var(--r-card);
    border-width: 1px; border-style: solid; transition: border-color .25s, background .25s; }
  .bento-card h3 { font-size: var(--t-h5); }
  .bento-card p { color: var(--muted); font-size: .98rem; }
  .b-wide { grid-column: span 4; }
  .b-cell { grid-column: span 2; }
  /* "Any input becomes video": three stacked input chips flow into the video,
     the homepage Decks/Reports/Knowledge merge concept laid out horizontally. */
  .input-flow { margin-top: auto; display: flex; align-items: center; justify-content: center; gap: 1.25rem; }
  .input-stack { display: flex; flex-direction: column; gap: .6rem; flex: 0 0 auto; }
  .input-node { display: inline-flex; align-items: center; gap: .5rem; padding: .55rem .85rem;
    border-radius: var(--radius-sm); border: 1px solid var(--border-soft); background: var(--panel); color: var(--muted);
    font-family: var(--font-head); font-weight: 600; font-size: .85rem; }
  .input-node .material-symbols-outlined { font-size: 18px; color: var(--cyan); flex: 0 0 auto; }
  .flow-arrow { font-size: 26px; color: var(--cyan); flex: 0 0 auto; }
  .input-video { flex: 0 1 auto; width: 360px; max-width: 100%; }
  @media (max-width: 560px) {
    .input-flow { flex-direction: column; align-items: stretch; gap: .85rem; }
    .input-stack { width: 100%; }
    .flow-arrow { transform: rotate(90deg); align-self: center; }
    .input-video { max-width: none; }
  }

  /* ===========================================================
     SERVICE FEATURE BLOCK  (Automark alternating feature)
     =========================================================== */
  .feature-block { border-radius: var(--radius);
    border-width: 1px; border-style: solid; overflow: hidden; }
  .fb-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .fb-copy { padding: clamp(2rem, 1.5rem + 2vw, 3.25rem); }
  .fb-copy h2 { max-width: 16ch; margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem); }
  .fb-items { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.9rem 1.5rem; }
  .fb-item .icon { width: 42px; height: 42px; margin-bottom: .9rem; }
  .fb-item .icon svg { width: 22px; height: 22px; }
  .fb-item h3 { font-size: var(--t-h6); margin-bottom: .35rem; }
  .fb-item p { color: var(--muted); font-size: .95rem; }
  .fb-media { background: transparent; padding: clamp(1.5rem, 1rem + 2vw, 3rem); display: grid; place-items: center; }
  /* the service video shares the same panel color the copy sits on, so the block reads as one surface */
  .fb-media .video-frame { background: transparent; box-shadow: none; }

  /* ===========================================================
     WHY IT WORKS  (proof-carrying cards: the PROOF leads visually,
     the claim sits above as context, fintech sits deliberately
     quieter as a flagged content gap)
     =========================================================== */
  .wiw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .wiw-card { display: flex; flex-direction: column; gap: .85rem; position: relative; }
  .wiw-claim { font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; line-height: 1.25; color: var(--body-copy); }
  .wiw-rule { height: 1px; background: var(--border-soft); }
  .wiw-proof { display: flex; flex-direction: column; gap: .6rem; }
  .wiw-client { font-family: var(--font-head); font-weight: 800; font-size: 1.3rem; color: var(--ink); letter-spacing: .01em; }
  .wiw-figures { color: var(--body-copy); font-size: 1.02rem; line-height: 1.5; }
  .wiw-card .stat { color: var(--cyan-bright); font-weight: 700; }
  .wiw-card.lighter { border-style: dashed; }
  .wiw-card.lighter .wiw-client { font-size: .8rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted); font-weight: 700; }
  .wiw-card.lighter .wiw-figures { color: var(--muted); }
  /* per-card secondary CTA: nav button style (btn-outline btn-sm), pinned to the
     card base; the ::after overlay keeps the whole card clickable (one anchor, valid markup) */
  .wiw-cta { margin-top: auto; align-self: flex-start; }
  .wiw-cta::after { content: ""; position: absolute; inset: 0; }

  /* ===========================================================
     FAQ ACCORDION  (Automark Faq; pure-CSS <details>, no JS)
     =========================================================== */
  .faq-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr); gap: clamp(2rem, 1rem + 3vw, 4rem); align-items: start; }
  .faq-intro { display: flex; flex-direction: column; align-items: flex-start; gap: 1.1rem; }
  .faq-intro .video-master { width: 100%; margin-top: .75rem; }
  .faq-list { display: flex; flex-direction: column; gap: 1rem; }
  .faq-item { border-width: 1px; border-style: solid; border-radius: var(--r-card); overflow: hidden; }
  .faq-item summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.2rem 1.4rem; font-family: var(--font-head); font-weight: 600; font-size: 1.05rem; color: var(--ink); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item .chev { color: var(--cyan); flex: 0 0 auto; font-size: 22px; transition: transform .25s ease; }
  .faq-item[open] .chev { transform: rotate(180deg); }
  .faq-body { padding: 0 1.4rem 1.25rem; color: var(--muted); line-height: 1.6; }

  /* ===========================================================
     RESPONSIVE (page-specific breakpoints)
     =========================================================== */
  @media (max-width: 1080px) {
    .wiw-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 980px) {
    .bento { grid-template-columns: 1fr; }
    .b-wide, .b-cell { grid-column: auto; }
    .fb-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
    .faq-intro { position: static; }
  }
  @media (max-width: 640px) {
    .wiw-grid { grid-template-columns: 1fr; }
    .fb-items { grid-template-columns: 1fr; }
  }

  /* card + CTA dark treatment handled globally in global.css */
</style>
