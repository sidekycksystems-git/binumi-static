---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Binumi · Book a demo"
  description="See what becomes possible when your organization's expertise becomes precision video at scale. Book a demo or start a proof of value with the Binumi team."
>
  <main>
    <section class="section contact" id="contact">
      <div class="container">

        <div class="contact-hero">
          <h1>See what becomes <span class="hl">possible</span>.</h1>
          <p class="lead">
            Book a demo and we will show you exactly where precision video can create measurable
            impact across your organization. No obligation. Results within weeks.
          </p>
        </div>

        <div class="contact-form-wrap">
          <!-- HubSpot form drop-in: replace the <form> below with the HubSpot embed (target <div> + loader script) when ready. Keep this wrapper for styling. -->
          <form>
            <div class="field">
              <label for="contact-name">Full name</label>
              <input type="text" id="contact-name" name="name" autocomplete="name" />
            </div>
            <div class="field">
              <label for="contact-email">Work email</label>
              <input type="email" id="contact-email" name="email" autocomplete="email" />
            </div>
            <div class="field">
              <label for="contact-company">Company</label>
              <input type="text" id="contact-company" name="company" autocomplete="organization" />
            </div>
            <div class="field">
              <label for="contact-message">How can we help?</label>
              <textarea id="contact-message" name="message" rows="5"></textarea>
            </div>
            <button class="btn btn-primary" type="submit">Book your demo</button>
          </form>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact {
    padding-block: var(--section-y, 5rem);
  }

  .contact .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .contact-hero {
    text-align: center;
    max-width: 42rem;
  }

  .contact-hero h1 {
    margin-bottom: 1rem;
  }

  .contact-form-wrap {
    width: 100%;
    max-width: 36rem;
    background: var(--surface);
    border: 1px solid var(--cyan);
    border-radius: var(--r-card);
    padding: 2.5rem;
  }

  .contact-form-wrap form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form-wrap .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-form-wrap label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
  }

  .contact-form-wrap input,
  .contact-form-wrap textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--ink);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }

  .contact-form-wrap input:focus,
  .contact-form-wrap textarea:focus {
    outline: none;
    border-color: var(--cyan);
  }

  .contact-form-wrap textarea {
    resize: vertical;
  }

  .contact-form-wrap .btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
</style>
