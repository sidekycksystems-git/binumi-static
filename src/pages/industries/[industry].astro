---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoFrame from '../../components/VideoFrame.astro';
import { industries, type Industry } from '../../data/industries.ts';

export function getStaticPaths() {
  return industries.map((i) => ({ params: { industry: i.slug }, props: { industry: i } }));
}

interface Props { industry: Industry; }
const { industry } = Astro.props;
---
<BaseLayout
  title={industry.title}
  description={industry.description}
  current="industries"
>

  <!-- ===================== PAGE-LEVEL: BREADCRUMB ===================== -->
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="container crumb-inner">
      <a href="/solutions/">Solution</a>
      <span class="sep" aria-hidden="true">/</span>
      <span class="crumb-current" aria-current="page">{industry.navLabel}</span>
    </div>
  </nav>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: new URL('/solutions/', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: industry.navLabel, item: new URL(Astro.url.pathname, Astro.site).href },
    ],
  })} />

  <main>
    <!-- ===================== BLOCK 1: HERO ===================== -->
    <section class="hero">
      <div class="container hero-inner">
        <h1 set:html={industry.hero.h1}></h1>
        <p class="lead">
          {industry.hero.lead}
        </p>
        <a class="btn btn-primary" href="/contact/">Start your proof of value
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
        <VideoFrame label={`${industry.name} brand film`} videoSrc="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__b4979381d628b6f7372b4d11b18bd9be_h169.mp4" />
      </div>
    </section>

    <!-- ===================== BLOCK 2: WHAT BINUMI DOES ===================== -->
    <section class="section">
      <div class="container">
        <div class="couplet">
          <p class="lead-line">Binumi is two things working as one.</p>
          <div class="couplet-grid reveal">
            <div class="card">
              <span class="kicker muted">The platform is the scale</span>
              <p>{industry.couplet.platform}</p>
            </div>
            <div class="card">
              <span class="kicker">The service is the expertise</span>
              <p>{industry.couplet.service}</p>
            </div>
          </div>
          <p class="close-line" set:html={industry.couplet.close}></p>
        </div>
      </div>
    </section>

    <!-- ===================== BLOCK 3 + 4: THE PROBLEM + PROOF (left) and VIDEO (right) ===================== -->
    <section class="section">
      <div class="container">
        <div class="proof-row">
          <p class="lead-line">{industry.proof.leadLine}</p>
          <div class="problem-proof">
            <div class="proof-col">
              <div class="problem reveal">
                {industry.proof.problem.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
              <div class="proof-interim reveal">
                <p set:html={industry.proof.interim}></p>
              </div>
            </div>
            <VideoFrame class="reveal" label={`${industry.name} proof video`} videoSrc={industry.video} autoplay muted loop />
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== BLOCK 5: USE CASES ===================== -->
    <section class="section">
      <div class="container">
        <div class="usecases">
          <p class="lead-line">{industry.usecases.leadLine}</p>
          <div class="chips reveal">
            {industry.usecases.chips.map((c) => (
              <span class="chip" set:html={c}></span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== BLOCK 6: TRUST ===================== -->
    <section class="section">
      <div class="container">
        <div class="trust reveal">
          <div class="trust-copy">
            <span class="kicker">{industry.trust.kicker}</span>
            <h2>{industry.trust.h2}</h2>
            <div class="creds" set:html={industry.trust.creds}></div>
            <p class="close">{industry.trust.close}</p>
          </div>
          <VideoFrame label={`${industry.name} trust video`} videoSrc={industry.video} autoplay muted loop />
        </div>
      </div>
    </section>

    <!-- ===================== BLOCK 7: CLOSING CTA ===================== -->
    <section class="section" id="cta">
      <div class="container">
        <div class="cta-card">
          <video class="cta-bg" src="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__e9fd886d8dacac140457e375d606c8a0_h169.mp4"
            autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
          <div class="inner">
            <h2 set:html={industry.cta.h2}></h2>
            <a class="btn btn-primary" href="/contact/">Start your proof of value
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

</BaseLayout>
