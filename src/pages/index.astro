---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoFrame from '../components/VideoFrame.astro';
import HowAccordion from '../components/HowAccordion.astro';

// Five-stage "How Binumi works" accordion content for the homepage.
const homeSteps = [
  {
    label: 'Identify',
    glyph: '<span class="material-symbols-outlined" aria-hidden="true">search</span>',
    body: 'We work with you to identify where precision video communications can create measurable impact across sales, workforce education, customer engagement, and knowledge transfer.',
  },
  {
    label: 'Configure',
    glyph: '<span class="material-symbols-outlined" aria-hidden="true">settings</span>',
    body: 'We configure Binumi around your brand, content, governance, and objectives, creating the foundations for scalable communications from day one.',
  },
  {
    label: 'Deliver',
    glyph: '<span class="material-symbols-outlined" aria-hidden="true">verified_user</span>',
    body: 'Our team helps deliver immediate results, supporting priority initiatives and demonstrating value within weeks rather than months.',
  },
  {
    label: 'Enable',
    glyph: '<span class="material-symbols-outlined" aria-hidden="true">how_to_reg</span>',
    body: 'Your experts and teams learn how to create, adapt, and scale communications themselves, reducing dependency on agencies and specialist resources.',
  },
  {
    label: 'Scale',
    glyph: '<span class="material-symbols-outlined" aria-hidden="true">bar_chart</span>',
    body: 'Video becomes an organizational capability, supporting every opportunity, every workforce, and every stage of growth without increasing headcount.',
  },
];
---
<BaseLayout
  title="Binumi · Scale expertise, grow revenue"
  description="Binumi helps organizations transform complex knowledge into precision video communications that support every sales opportunity, educate every workforce, and let experts influence thousands rather than dozens."
>
  <main>
    <!-- ===================== HERO (Variant B: white editorial + transformation row) ===================== -->
    <section class="hero hero-home hero-editorial">
      <div class="container hero-inner">
        <h1 class="hero-head">Scale Expertise. <span class="hl">Grow Revenue</span>.</h1>

        <div class="hero-copy">
            <p class="lead">
              Revenue is limited by how many people your experts can reach. Binumi helps organizations
              transform complex knowledge into precision video communications that support every sales
              opportunity, educate every workforce, and enable their most valuable people to influence
              thousands rather than dozens.
            </p>
            <div class="hero-cta">
              <a class="btn btn-primary" href="/contact/">Start your proof of value
                <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
              </a>
            </div>
            <ul class="hero-trust">
              <li>
                <span class="material-symbols-outlined" aria-hidden="true">shield</span>
                ISO 27001 certified
              </li>
              <li>
                <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                Brand-locked output
              </li>
            </ul>
            <dl class="hero-proof">
              <div class="hp-cell"><dt><img src="/logo-fujitsu.png" alt="Fujitsu" /></dt><dd>£20M+ in opportunities supported</dd></div>
              <div class="hp-cell"><dt><img src="/logo-informa.png" alt="Informa" /></dt><dd>200+ videos in 3 months</dd></div>
              <div class="hp-cell"><dt><img src="/logo-generali.png" alt="Generali" /></dt><dd>Localized in 12 languages</dd></div>
              <div class="hp-cell"><dt><img src="/logo-knight-frank.png" alt="Knight Frank" /></dt><dd>Two weeks to two hours</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== WE DRIVE REVENUE WITH VIDEO (text left, brand film right) ===================== -->
    <section class="section" id="drive">
      <div class="container split">
        <div class="copy-col">
          <h2>We <span class="hl">drive revenue</span> with video.</h2>
          <p class="lead">Binumi uses AI to turn your company's existing knowledge, content, and expertise into polished, on-brand videos in minutes.</p>
        </div>
        <div class="drive-media">
          <VideoFrame
            label="Binumi brand film"
            videoSrc="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__eff639274fe438f8e6950573373faf76_h169.mp4"
            autoplay
            muted
            loop
          />
          <svg class="drive-merge" viewBox="0 0 1000 100" preserveAspectRatio="none" aria-hidden="true">
            <path d="M500 0 V68 M166 68 H834 M166 68 V100 M500 68 V100 M834 68 V100" fill="none" stroke="var(--cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
          </svg>
          <div class="drive-inputs">
            <span class="node">
              <span class="material-symbols-outlined" aria-hidden="true">slideshow</span>
              Decks
            </span>
            <span class="node">
              <span class="material-symbols-outlined" aria-hidden="true">description</span>
              Reports
            </span>
            <span class="node">
              <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span>
              Knowledge
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== WHERE BINUMI CREATES VALUE (Home_03) ===================== -->
    <section class="section" id="value">
      <div class="container stack">
        <div class="intro">
          <h2>Where Binumi <span class="hl">creates value</span></h2>
        </div>
        <!-- Spotlight tabs: a horizontal row of value areas (top) drives one focal panel below.
             Toggle logic in the inline script below; one panel open at a time. -->
        <div class="value-wrap reveal">
          <div class="value-rail" role="tablist" aria-label="Value areas">
            <button class="value-tab active" type="button" role="tab" data-i="0" aria-selected="true">Revenue Growth</button>
            <button class="value-tab" type="button" role="tab" data-i="1" aria-selected="false">Workforce Capability</button>
            <button class="value-tab" type="button" role="tab" data-i="2" aria-selected="false">Customer Engagement</button>
            <button class="value-tab" type="button" role="tab" data-i="3" aria-selected="false">Operational Efficiency</button>
          </div>
          <div class="value-stage">
            <article class="value-panel active" data-i="0">
              <h3>Revenue Growth</h3>
              <p>Support every pitch, proposal, and sales opportunity with precision video communications that help buyers understand, engage, and act.</p>
              <span class="value-graphic" aria-hidden="true"><span class="material-symbols-outlined">trending_up</span></span>
            </article>
            <article class="value-panel" data-i="1">
              <h3>Workforce Capability</h3>
              <p>Transform complex knowledge into scalable learning experiences that improve onboarding, training, compliance, internal communications, and professional development.</p>
              <span class="value-graphic" aria-hidden="true"><span class="material-symbols-outlined">psychology</span></span>
            </article>
            <article class="value-panel" data-i="2">
              <h3>Customer Engagement</h3>
              <p>Help customers understand products, services, processes, and decisions through clear, consistent communications.</p>
              <span class="value-graphic" aria-hidden="true"><span class="material-symbols-outlined">smart_display</span></span>
            </article>
            <article class="value-panel" data-i="3">
              <h3>Operational Efficiency</h3>
              <p>Reduce dependency on agencies, repetitive meetings, and additional headcount by scaling expert communication across the business.</p>
              <span class="value-graphic" aria-hidden="true"><span class="material-symbols-outlined">settings</span></span>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== BE VIDEO FIRST (Home_02) ===================== -->
    <section class="section" id="be-video-first">
      <div class="container split">
        <div class="copy-col">
          <h2>Video is the output. <span class="hl">Growth is the goal</span>.</h2>
          <p class="lead">Your experts already create value. Binumi helps that value scale.</p>
          <p class="lead">
            Binumi identifies where precision video can support sales, learning, customer engagement,
            and knowledge transfer, then configures the AI, workflows, brand controls, and specialist
            support to deliver measurable impact.
          </p>
        </div>
        <VideoFrame label="Video is the output, growth is the goal" videoSrc="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__b4979381d628b6f7372b4d11b18bd9be_h169.mp4" />
      </div>
    </section>

    <!-- ===================== CAPABILITY (split: video left, copy right) ===================== -->
    <section class="section" id="reframe">
      <div class="container split split--flip">
        <VideoFrame label="Capability overview video" videoSrc="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__540d1186595af35d922ea8b71e37123e_h169.mp4" />
        <div class="copy-col">
          <h2>Video isn&rsquo;t a project. It&rsquo;s <span class="hl">a capability</span>.</h2>
          <p class="lead">Most organizations treat video as a one-off request.</p>
          <p class="lead">
            Binumi makes it a repeatable business capability, built to scale expertise, accelerate
            understanding, and support growth across the organization.
          </p>
        </div>
      </div>
    </section>

    <!-- ===================== HOW BINUMI WORKS (two-column: copy left, accordion right) ===================== -->
    <!-- Numbered accordion: one stage open at a time. Structure/styles live in the
         HowAccordion component; toggle logic in its inline script. -->
    <section class="section" id="how">
      <div class="container split">
        <div class="copy-col">
          <h2>How <span class="hl">Binumi</span> works</h2>
          <p class="lead">
            Not a platform you are left to figure out. Not an agency you become dependent on.
            Binumi combines specialist services, AI, and purpose-built technology to help organizations
            scale expertise, drive revenue, and build long-term communication capability.
          </p>
        </div>
        <HowAccordion idPrefix="how-step" steps={homeSteps} />
      </div>
    </section>

    <!-- ===================== PROOF (outcomes + credentials + testimonial) ===================== -->
    <section class="section" id="proof">
      <div class="container stack" style="position:relative;">
        <div class="intro">
          <h2>Real clients, <span class="hl">in detail</span>.</h2>
          <p class="subtitle">A closer look at the organizations we support, in their own numbers, not borrowed industry statistics.</p>
        </div>

        <!-- Featured outcomes -->
        <div class="grid grid-3 reveal">
          <div class="proof">
            <div class="client"><h3 class="name">Fujitsu</h3><span class="descr">$37B global technology and services provider</span></div>
            <ul>
              <li><span class="stat">Every</span> sales meeting, video-supported.</li>
              <li><span class="stat">5&times;</span> post-meeting engagement.</li>
              <li><span class="stat">&pound;20M+</span> in opportunities supported.</li>
            </ul>
          </div>
          <div class="proof">
            <div class="client"><h3 class="name">Informa</h3><span class="descr">FTSE 100 leader in intelligence and B2B events</span></div>
            <ul>
              <li><span class="stat">200+</span> videos in the first 3 months.</li>
              <li><span class="stat">New</span> video revenue stream created.</li>
              <li><span class="stat">Sponsor value</span> extended beyond the event.</li>
            </ul>
          </div>
          <div class="proof">
            <div class="client"><h3 class="name">Generali</h3><span class="descr">One of the world&rsquo;s largest insurance and asset management groups</span></div>
            <ul>
              <li><span class="stat">Video</span> communications scaled across Europe.</li>
              <li><span class="stat">Instantly</span> localized in 12 languages.</li>
              <li><span class="stat">One message.</span> Every market.</li>
            </ul>
          </div>
        </div>

        <!-- Quieter credential band -->
        <div class="credential reveal">
          <p>Plus <span class="names">Netcetera, Imagine Learning</span> and many more.</p>
        </div>

        <!-- Testimonials, two-up -->
        <div class="testimonials reveal">
          <div class="testimonial">
            <div class="qmark"><svg viewBox="0 0 45 28" fill="currentColor"><path d="M15.4 0v11H24.9L16.6 28H0L13 0h2.4ZM36.7 0v11H45L36.7 28H21.3L34.3 0h2.4Z"/></svg></div>
            <blockquote>
              Binumi has changed how we sell. It helps our experts support every opportunity with
              precise, high-impact video communications that make complex ideas easier to understand
              and faster to act on. It is not another tool. It is a capability for scaling expertise
              and driving revenue.
            </blockquote>
            <div class="attribution">
              <span class="avatar"></span>
              <span class="who"><b>CTO</b><span>Fujitsu</span></span>
            </div>
          </div>

          <div class="testimonial">
            <div class="qmark"><svg viewBox="0 0 45 28" fill="currentColor"><path d="M15.4 0v11H24.9L16.6 28H0L13 0h2.4ZM36.7 0v11H45L36.7 28H21.3L34.3 0h2.4Z"/></svg></div>
            <blockquote>
              Binumi enables us to create accurate, targeted video at a scale our business demands,
              unlocking new opportunities for engagement and revenue growth. They don&rsquo;t just
              provide technology; they bring the expertise, support and strategic thinking that make
              video deliver real commercial value.
            </blockquote>
            <div class="attribution">
              <span class="avatar"></span>
              <span class="who"><b>Jean Pierre Bird</b><span>Global Commercial Director, Informa</span></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CLOSE ===================== -->
    <section class="section" id="close">
      <div class="container">
        <div class="cta-card">
          <video class="cta-bg" src="https://d27kwhqqz0gcvq.cloudfront.net/uploads/1__e9fd886d8dacac140457e375d606c8a0_h169.mp4"
            autoplay muted loop playsinline preload="auto" aria-hidden="true"></video>
          <div class="inner">
            <h2>See where Binumi <span class="hl">creates impact</span>.</h2>
            <p class="subtitle">Explore how precision video communications can support sales, workforce education, customer engagement, internal communications, and knowledge transfer across your organization.</p>
            <a class="btn btn-primary" href="/contact/">See the opportunities
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  /* Stack the new client descriptor under the client name in the proof cards. */
  #proof .proof .client { flex-direction: column; align-items: flex-start; gap: .3rem; }
  #proof .proof .descr { color: var(--muted); font-size: .9rem; font-weight: 400; }

  /* Hero (Variant B): white editorial copy block + transformation row */
  /* Match the solutions hero spacing: the same clamp it uses, plus the fixed
     header's height (5.5rem) since this page's header overlaps instead of pushing. */
  .hero-editorial { background: var(--bg); padding-top: calc(5.5rem + var(--nav-to-hero)); padding-bottom: var(--section-y); }
  /* hero-inner stacks the full-width headline, then the split row. The headline sits
     tight to the subhead (its own gap), not the full --gap block rhythm. */
  .hero-editorial .hero-inner { display: flex; flex-direction: column; align-items: flex-start; text-align: left; gap: clamp(1rem, .5rem + 1.5vw, 2rem); }
  .hero-editorial .hero-head { letter-spacing: -0.02em; line-height: 1.08; }

  /* Single-column editorial: copy, CTA, trust, and the proof row stacked. */
  .hero-editorial .hero-copy { width: 100%; display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  .hero-editorial .lead { max-width: none; line-height: 1.7; color: var(--body-copy); }

  /* Hero proof: all four named-client outcomes on one line, each in a light island
     box styled like the testimonial (surface fill, cyan hairline, card radius). */
  .hero-proof { margin: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; width: 100%; }
  .hero-proof .hp-cell { background: var(--surface); border: 1px solid var(--cyan); border-radius: var(--r-card); padding: 1.25rem; }
  .hero-proof dt { line-height: 0; }
  .hero-proof dt img { height: 26px; width: auto; max-width: 100%; vertical-align: middle; }
  .hero-proof dd { margin: .6rem 0 0; color: var(--muted); font-size: .9rem; }
  .hero-trust { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap;
    gap: .55rem 1.75rem; color: var(--muted); font-size: .9rem; }
  .hero-trust li { display: flex; align-items: center; gap: .5rem; }
  .hero-trust li .material-symbols-outlined { font-size: 18px; flex: 0 0 auto; color: var(--muted); }

  @media (max-width: 860px) { .hero-proof { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .hero-proof { grid-template-columns: 1fr; } }

  /* "We drive revenue with video": text left, the brand film right with its inverted
     merge bracket gathering the Decks / Reports / Knowledge inputs up into the film. */
  #drive .drive-media { display: flex; flex-direction: column; align-items: stretch; }
  #drive .drive-media .video-master { width: 100%; }
  #drive .drive-merge { width: 100%; height: 46px; display: block; }
  #drive .drive-inputs { display: grid; grid-template-columns: repeat(3, 1fr); justify-items: center; }
  #drive .drive-inputs .node { display: inline-flex; align-items: center; gap: .5rem; padding: .5rem .8rem;
    border-radius: var(--radius-sm); border: 1px solid var(--border-soft); background: var(--panel); color: var(--muted);
    font-family: var(--font-head); font-weight: 600; font-size: .85rem; }
  #drive .drive-inputs .node .material-symbols-outlined { font-size: 18px; color: var(--cyan); flex: 0 0 auto; }
  /* .split collapses to one column at 860; drop the bracket and let chips wrap. */
  @media (max-width: 860px) {
    #drive .drive-merge { display: none; }
    #drive .drive-inputs { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: 1rem; }
  }

  /* "Where Binumi creates value" spotlight tabs: a horizontal row of labels (top) drives one focal panel below. */
  #value .value-wrap { display: flex; flex-direction: column; gap: 1.5rem; max-width: 64rem; margin: 1rem auto 0; width: 100%; }
  #value .value-rail { display: flex; flex-direction: row; flex-wrap: wrap; justify-content: center; gap: .25rem; border-bottom: 1px solid var(--border); }
  #value .value-tab { all: unset; box-sizing: border-box; display: flex; align-items: center; cursor: pointer;
    font-family: var(--font-head); font-weight: 700; font-size: 1.05rem; color: var(--muted);
    padding: .9rem 1.1rem; margin-bottom: -1px; border-bottom: 2px solid transparent;
    transition: background .2s, border-color .2s, color .2s; }
  #value .value-tab:hover { background: rgba(11,20,40,.04); color: var(--ink); }
  #value .value-tab:focus-visible { outline: 2px solid var(--cyan); outline-offset: -2px; }
  #value .value-tab.active { border-bottom-color: var(--cyan); background: var(--cyan-fill); color: var(--ink); }
  /* All panels share one grid cell, so the stage always sizes to the tallest panel:
     the section height is constant and the page never jumps between hovers. Inactive
     panels stay in flow (height held) but fade out via opacity for a smooth crossfade. */
  #value .value-stage { display: grid; }
  #value .value-panel { grid-area: 1 / 1; display: grid; grid-template-columns: 1fr auto; column-gap: 1.5rem; align-items: start;
    padding: 2.5rem; border: 1px solid var(--cyan); border-radius: var(--r-card);
    background: var(--surface); color: var(--body-copy); min-height: 15rem;
    opacity: 0; visibility: hidden; transform: translateY(6px); pointer-events: none;
    transition: opacity .3s ease, transform .3s ease, visibility .3s; }
  #value .value-panel.active { opacity: 1; visibility: visible; transform: none; pointer-events: auto; }
  @media (prefers-reduced-motion: reduce) { #value .value-panel { transition: opacity .15s linear; transform: none; } }
  #value .value-panel h3 { grid-column: 1; font-size: var(--t-h4); margin-bottom: .8rem; }
  #value .value-panel p { grid-column: 1; color: var(--body-copy); font-size: 1.1rem; max-width: 46ch; }
  #value .value-graphic { grid-column: 2; grid-row: 1 / span 2; align-self: center; justify-self: end; display: grid; place-items: center; color: var(--cyan); opacity: .12; pointer-events: none; }
  #value .value-graphic .material-symbols-outlined { font-size: 150px; line-height: 1; }
  @media (max-width: 860px) {
    #value .value-tab { padding: .7rem 1rem; font-size: .98rem; }
    #value .value-panel { padding: 1.8rem; grid-template-columns: 1fr; }
    #value .value-graphic { display: none; }
  }

  /* "How Binumi works": two-column split, copy left / accordion right. Top-align
     so the heading sits level with the first accordion row, not centered against
     the tall accordion. The accordion shows bare on the white page (no box). */
  #how .split { align-items: start; }
  #how .how-acc { margin: 0; }

</style>

<script is:inline>
  /* "Where Binumi creates value" spotlight tabs: hover, focus, or click swaps the panel. */
  (function () {
    var tabs = document.querySelectorAll('#value .value-tab');
    var panels = document.querySelectorAll('#value .value-panel');
    function select(i) {
      Array.prototype.forEach.call(tabs, function (t) {
        var on = t.getAttribute('data-i') === i;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      Array.prototype.forEach.call(panels, function (p) {
        p.classList.toggle('active', p.getAttribute('data-i') === i);
      });
    }
    Array.prototype.forEach.call(tabs, function (tab) {
      var i = tab.getAttribute('data-i');
      tab.addEventListener('mouseenter', function () { select(i); });
      tab.addEventListener('focus', function () { select(i); });
      tab.addEventListener('click', function () { select(i); });
    });
  })();
</script>
