---
import VideoFrame from './VideoFrame.astro';

interface Props {
  post: any;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const data = post.data;

const fmtDate = (date: Date) =>
  new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(date);
---

{featured ? (
  <a class="featured reveal" href={`/insights/${post.id}/`} aria-label={`Read: ${data.heading}`}>
    <VideoFrame videoSrc={data.heroVideoSrc} poster={data.heroVideoPoster} label="Featured insight video" />
    <div class="featured-copy">
      <span class="post-cat">{data.category}</span>
      <h2>{data.heading}</h2>
      <p>{data.deck}</p>
      <div class="post-meta">
        <span>{fmtDate(data.date)}</span>
      </div>
      <span class="read-link">Watch the insight
        <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
      </span>
    </div>
  </a>
) : data.status === 'planned' ? (
  <article class="post-card post-card--planned">
    <VideoFrame small label={`${data.cardTag} insight video`} />
    <div class="post-card-body">
      <span class="post-cat">{data.category}</span>
      <h3>{data.heading}</h3>
      <p>{data.deck}</p>
      <div class="post-meta"><span>{fmtDate(data.date)}</span></div>
    </div>
  </article>
) : (
  <a class="post-card" href={`/insights/${post.id}/`}>
    <VideoFrame small videoSrc={data.heroVideoSrc} poster={data.heroVideoPoster} label={`${data.cardTag} insight video`} />
    <div class="post-card-body">
      <span class="post-cat">{data.category}</span>
      <h3>{data.heading}</h3>
      <p>{data.deck}</p>
      <div class="post-meta"><span>{fmtDate(data.date)}</span></div>
    </div>
  </a>
)}

<style is:global>
  /* ===========================================================
     POST CARD anatomy  (shared label/meta/read-link bits)
     =========================================================== */
  .post-cat { font-family: var(--font-head); font-weight: 700; font-size: .72rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--cyan-text); }
  .post-meta { display: flex; align-items: center; gap: .55rem; color: var(--muted); font-size: .85rem; }
  .read-link { display: inline-flex; align-items: center; gap: .45rem; color: var(--cyan-text); font-weight: 500; }
  .read-link .material-symbols-outlined { font-size: 18px; transition: transform .2s; }

  /* ===========================================================
     FEATURED LEAD POST  (split: cinematic video + copy)
     =========================================================== */
  .featured { display: grid; grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
    gap: clamp(1.75rem, 1rem + 3vw, 3.25rem); align-items: center;
    border-width: 1px; border-style: solid; border-radius: var(--r-card);
    padding: clamp(1.1rem, .9rem + 1vw, 1.6rem); transition: border-color .25s, background .25s; }
  .featured:hover .read-link .material-symbols-outlined { transform: translateX(3px); }
  .featured-copy { display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; padding-block: .5rem; }
  .featured-copy h2 { font-size: var(--t-h3); max-width: 18ch; text-wrap: balance; }
  .featured-copy p { color: var(--muted); }

  /* ===========================================================
     POST GRID  (uniform cards, video on top)
     =========================================================== */
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .post-card { display: flex; flex-direction: column; overflow: hidden; border-radius: var(--r-card);
    border-width: 1px; border-style: solid;
    transition: border-color .25s, background .25s, transform .25s; }
  .post-card:hover { transform: translateY(-3px); }
  .post-card--planned { cursor: default; }
  .post-card--planned:hover { transform: none; }
  .post-card-body { padding: 1.4rem 1.5rem 1.6rem; display: flex; flex-direction: column; gap: .55rem; flex: 1 1 auto; }
  .post-card-body h3 { font-size: var(--t-h6); line-height: 1.28; }
  .post-card-body p { color: var(--muted); font-size: .95rem; }
  .post-card-body .post-meta { margin-top: auto; padding-top: .4rem; }

  /* ===========================================================
     RESPONSIVE
     =========================================================== */
  @media (max-width: 1080px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 980px) {
    .featured { grid-template-columns: 1fr; }
    .featured-copy { padding-block: 0 .5rem; }
  }
  @media (max-width: 620px) { .posts-grid { grid-template-columns: 1fr; } }

  /* card dark treatment handled globally in global.css */
</style>
