---
interface Props {
  /** Which nav section is active: 'solution' | 'industries' | 'insights' | undefined (home) */
  current?: 'solution' | 'industries' | 'insights';
  /** Header CTA target. Homepage passes '#close'; all other pages use the default '#cta'. */
  ctaHref?: string;
}
const { current, ctaHref = '/contact/' } = Astro.props;

// Nav: Solution (flat link) / Industries (mega-menu) / Insights (flat link).
// The Industries <summary> is a trigger only, not a link: Industries has no
// landing page of its own (the old hub became /solutions/), but every cluster
// item links to its /industries/{slug}/ page. Five clusters; Events is the 15th
// industry, first in the Events, Travel, Public & Education cluster.
const industryClusters = [
  {
    heading: 'Financial & Professional',
    items: [
      { label: 'Financial Services', href: '/industries/financial-services/' },
      { label: 'Professional Services', href: '/industries/professional-services/' },
    ],
  },
  {
    heading: 'Technology & Communications',
    items: [
      { label: 'Technology & Software', href: '/industries/technology/' },
      { label: 'Telecommunications', href: '/industries/telecommunications/' },
    ],
  },
  {
    heading: 'Industry & Infrastructure',
    items: [
      { label: 'Industrials & Manufacturing', href: '/industries/industrials/' },
      { label: 'Construction', href: '/industries/construction/' },
      { label: 'Energy & Utilities', href: '/industries/energy-utilities/' },
      { label: 'Automotive', href: '/industries/automotive/' },
    ],
  },
  {
    heading: 'Life Sciences & Healthcare',
    items: [
      { label: 'Life Sciences & Pharma', href: '/industries/life-sciences/' },
      { label: 'Healthcare', href: '/industries/healthcare/' },
    ],
  },
  {
    heading: 'Events, Travel, Public & Education',
    items: [
      { label: 'Events', href: '/industries/events/' },
      { label: 'Real Estate', href: '/industries/real-estate/' },
      { label: 'Travel, Transport & Hospitality', href: '/industries/travel-transport/' },
      { label: 'Public Sector', href: '/industries/public-sector/' },
      { label: 'Education', href: '/industries/education/' },
    ],
  },
];
---
<header class="site-header">
  <div class="container navbar">
    <a class="brand" href="/" aria-label="Binumi home"><img src="/binumi-logo-header.png" alt="Binumi" width="307" height="96" /></a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle menu">
      <span class="icon-menu material-symbols-outlined" aria-hidden="true">menu</span>
      <span class="icon-close material-symbols-outlined" aria-hidden="true">close</span>
    </label>
    <nav class="nav-links" aria-label="Primary">
      <a href="/solutions/" class={current === 'solution' ? 'current' : undefined} aria-current={current === 'solution' ? 'page' : undefined}>Solution</a>

      <details class="nav-item has-menu nav-industries">
        <summary class={current === 'industries' ? 'current' : undefined} aria-current={current === 'industries' ? 'page' : undefined}>
          Industries
          <span class="nav-caret material-symbols-outlined" aria-hidden="true">expand_more</span>
        </summary>
        <div class="nav-panel nav-panel--mega">
          <div class="mega-grid">
            {industryClusters.map((cluster) => (
              <div class="mega-col">
                <p class="mega-heading">{cluster.heading}</p>
                <ul class="nav-list">
                  {cluster.items.map((it) => (
                    <li><a href={it.href}>{it.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="mega-foot">
            <a class="mega-travels" href="/solutions/">Not listed? The model travels.</a>
          </div>
        </div>
      </details>

      <a href="/insights/" class={current === 'insights' ? 'current' : undefined} aria-current={current === 'insights' ? 'page' : undefined}>Insights</a>

      <div class="nav-links-cta">
        <a class="btn btn-primary btn-sm" href={ctaHref}>Start your proof of value</a>
        <a class="btn btn-outline btn-sm" href="/user/signin">Log in</a>
      </div>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-primary btn-sm" href={ctaHref}>Start your proof of value</a>
      <a class="btn btn-outline btn-sm nav-login" href="/user/signin">Log in</a>
    </div>
  </div>
</header>
