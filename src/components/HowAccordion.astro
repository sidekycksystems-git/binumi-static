---
// Shared "How Binumi works" numbered accordion. Renders the five-stage list with
// the nested Service/Platform bracket rail, one item open at a time. Structural,
// token-only styling lives here (white surface by default); pages re-skin it by
// overriding tokens on a scoping wrapper (e.g. the homepage navy island).
interface Step { label: string; glyph: string; body: string; }
const { idPrefix, steps } = Astro.props as { idPrefix: string; steps: Step[] };
---
<div class="how-acc reveal">
  <div class="acc-bracket acc-bracket-service" aria-hidden="true"><span class="acc-bracket-label">Service</span></div>
  <div class="acc-bracket acc-bracket-platform" aria-hidden="true"><span class="acc-bracket-label">Platform</span></div>
  {steps.map((s, i) => { const n = String(i+1).padStart(2,'0'); const id = `${idPrefix}-${n}`; return (
    <div class={i===0 ? 'acc-item open' : 'acc-item'}>
      <button class="acc-head" type="button" aria-expanded={i===0 ? 'true' : 'false'} aria-controls={id}>
        <span class="acc-glyph icon-chip" set:html={s.glyph}></span>
        <span class="acc-label">{s.label}</span>
        <span class="acc-chev material-symbols-outlined" aria-hidden="true">expand_more</span>
      </button>
      <div class="acc-panel" id={id}><div class="acc-panel-in"><p>{s.body}</p></div></div>
    </div>
  );})}
</div>

<style is:global>
  /* "How Binumi works" numbered accordion: one item open at a time, centered
     number/glyph/label, chevron pinned right, centered body copy. A nested
     Service/Platform bracket rail on the left wraps the rows: cyan Service around
     all five, muted Platform around the middle three. White surface by default;
     pages re-skin via token overrides on a scoping wrapper. */
  .how-acc { display: grid; grid-template-columns: [svc] 26px [plt] 32px [body] minmax(0, 1fr);
    grid-template-rows: repeat(5, auto); column-gap: 0; row-gap: 0; max-width: 64rem; margin-inline: auto; width: 100%; }
  .how-acc .acc-bracket { align-self: stretch; position: relative; margin-right: 8px;
    border: 1.5px solid var(--border); border-right: 0; border-radius: 3px 0 0 3px; }
  .how-acc .acc-bracket-service { grid-column: svc; grid-row: 1 / -1; border-color: var(--cyan); }
  .how-acc .acc-bracket-platform { grid-column: plt; grid-row: 2 / 5; border-color: var(--border); }
  .how-acc .acc-bracket-label { position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(180deg); writing-mode: vertical-rl;
    font-family: var(--font-head); font-weight: 700; font-size: .6rem; letter-spacing: .2em;
    text-transform: uppercase; white-space: nowrap; }
  .how-acc .acc-bracket-service .acc-bracket-label { color: var(--cyan-text); }
  .how-acc .acc-bracket-platform .acc-bracket-label { color: var(--muted); }
  .how-acc .acc-item { grid-column: body; border-bottom: 1px solid var(--border);
    transition: border-color .25s, background .25s; }
  .how-acc .acc-item:nth-child(3) { grid-row: 1; border-top: 1px solid var(--border); }
  .how-acc .acc-item:nth-child(4) { grid-row: 2; }
  .how-acc .acc-item:nth-child(5) { grid-row: 3; }
  .how-acc .acc-item:nth-child(6) { grid-row: 4; }
  .how-acc .acc-item:nth-child(7) { grid-row: 5; }
  .how-acc .acc-head { all: unset; box-sizing: border-box; position: relative; display: flex; align-items: center;
    justify-content: flex-start; gap: .85rem; width: 100%; padding: 1.4rem 3.5rem 1.4rem 1.25rem; cursor: pointer; }
  .how-acc .acc-head:focus-visible { outline: 2px solid var(--cyan); outline-offset: -2px; }
  /* Recipe inherited from global .icon-chip; this only sets size and keeps the transition. */
  .how-acc .acc-glyph { flex: none; --chip-size: 38px; --chip-icon: 22px;
    transition: background .25s, border-color .25s, color .25s; }
  .how-acc .acc-label { flex: none; text-align: left; font-family: var(--font-head); font-weight: 700; font-size: var(--t-h6);
    text-transform: uppercase; letter-spacing: .06em; color: var(--ink); }
  .how-acc .acc-chev { position: absolute; right: 1.5rem; top: 50%; transform: translateY(-50%);
    font-size: 22px; color: var(--cyan); transition: transform .25s ease; }
  .how-acc .acc-item.open .acc-chev { transform: translateY(-50%) rotate(180deg); }
  .how-acc .acc-panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .3s ease; }
  .how-acc .acc-item.open .acc-panel { grid-template-rows: 1fr; }
  .how-acc .acc-panel-in { overflow: hidden; }
  .how-acc .acc-panel p { margin: 0; color: var(--body-copy); font-size: 1.02rem; max-width: 60ch; text-align: left; padding: 0 1.5rem 1.5rem 1.25rem; }
  @media (max-width: 700px) {
    /* drop the bracket rail; the accordion flattens to a single stacked column */
    .how-acc { display: flex; flex-direction: column; max-width: 60rem; }
    .how-acc .acc-bracket { display: none; }
  }
  @media (max-width: 560px) {
    .how-acc .acc-head { gap: .6rem; padding: 1.2rem 2.6rem; }
    .how-acc .acc-chev { right: .9rem; }
    .how-acc .acc-panel p { padding: 0 1rem 1.25rem; }
  }
</style>

<script>
  /* "How Binumi works" accordion: single item open at a time. Works for any
     .how-acc on the page. */
  document.querySelectorAll('.how-acc').forEach((acc) => {
    acc.querySelectorAll('.acc-head').forEach((head) => {
      head.addEventListener('click', () => {
        const item = head.parentElement;
        const isOpen = item.classList.contains('open');
        acc.querySelectorAll('.acc-item').forEach((sib) => {
          sib.classList.remove('open');
          const b = sib.querySelector('.acc-head'); if (b) b.setAttribute('aria-expanded','false');
        });
        if (!isOpen) { item.classList.add('open'); head.setAttribute('aria-expanded','true'); }
      });
    });
  });
</script>
