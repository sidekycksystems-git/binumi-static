---
interface Props {
  class?: string;
  duration?: string;
  embedSrc?: string;
  videoSrc?: string;
  poster?: string;
  label?: string;
  small?: boolean;
  tag?: string;
  title?: string;
  autoplay?: boolean;
  muted?: boolean;
  loop?: boolean;
  controls?: boolean;
}

const {
  class: className = '',
  duration,
  embedSrc,
  videoSrc,
  poster,
  label,
  small = false,
  tag,
  title = 'Binumi video',
  autoplay = false,
  muted = false,
  loop = false,
  controls = true
} = Astro.props;

const frameRole = label && !embedSrc && !videoSrc ? 'img' : undefined;
---

{small ? (
  <div class={`thumb ${className}`.trim()} role={frameRole} aria-label={label}>
    {tag && <span class="video-tag">{tag}</span>}
    {videoSrc && <video src={videoSrc} poster={poster} muted playsinline preload="metadata"></video>}
    {duration && <span class="duration" aria-hidden="true"><span class="material-symbols-outlined" aria-hidden="true">play_arrow</span>{duration}</span>}
  </div>
) : (
  <div class={`video-master ${className}`.trim()} role={frameRole} aria-label={label}>
    <div class="video-frame">
      {tag && <span class="video-tag">{tag}</span>}
      {embedSrc ? (
        <iframe
          src={embedSrc}
          title={title}
          frameborder="0"
          scrolling="no"
          allow="fullscreen"
          allowfullscreen>
        </iframe>
      ) : videoSrc ? (
        <video
          src={videoSrc}
          title={title}
          poster={poster}
          controls={controls}
          playsinline
          data-autoplay={autoplay ? '' : undefined}
          muted={muted}
          loop={loop}
          preload={autoplay ? 'auto' : 'metadata'}>
        </video>
      ) : null}
      {duration && <span class="duration" aria-hidden="true"><span class="material-symbols-outlined" aria-hidden="true">play_arrow</span>{duration}</span>}
    </div>
  </div>
)}

